<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro de Clientes</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <main class="container">
      <h1>Cadastro de Clientes</h1>

      <% if (mensagemErro) { %>
        <div class="alerta erro"><%= mensagemErro %></div>
      <% } %>

      <% if (sucesso) { %>
        <div class="alerta sucesso"><%= sucesso %></div>
      <% } %>

      <section class="card">
        <h2>Novo Cliente</h2>
        <form action="/clientes" method="POST" class="form-grid">
          <label for="nome">Nome</label>
          <input type="text" id="nome" name="nome" placeholder="Ex: Maria Souza" required />

          <label for="cidade">Cidade</label>
          <input type="text" id="cidade" name="cidade" placeholder="Ex: São Paulo" required />

          <label for="nivel">Nível</label>
          <input type="text" id="nivel" name="nivel" placeholder="Ex: Ouro" required />

          <label for="atualizacao">Atualização</label>
          <input type="datetime-local" id="atualizacao" name="atualizacao" required />

          <button type="submit">Cadastrar</button>
        </form>
      </section>

      <section class="card">
        <h2>Clientes Cadastrados</h2>
        <div class="tabela-wrapper">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Cidade</th>
                <th>Nível</th>
                <th>Atualização</th>
              </tr>
            </thead>
            <tbody>
              <% if (clientes.length === 0) { %>
                <tr>
                  <td colspan="5" class="vazio">Nenhum cliente cadastrado.</td>
                </tr>
              <% } %>

              <% clientes.forEach((cliente) => { %>
                <tr>
                  <td><%= cliente.id %></td>
                  <td><%= cliente.nome %></td>
                  <td><%= cliente.cidade %></td>
                  <td><%= cliente.nivel %></td>
                  <td><%= new Date(cliente.atualizacao).toLocaleString('pt-BR') %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
